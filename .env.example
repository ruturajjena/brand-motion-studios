# Stripe secret key (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...) — from the endpoint registered
# in the Stripe dashboard pointing at /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# Canonical site URL, used as checkout redirect fallback
NEXT_PUBLIC_SITE_URL=https://brandmotion.in

# Supabase project — Settings > API in the dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — Settings > API. Server-only, never expose to
# the client. Used exclusively by the Stripe webhook to write entitlements.
SUPABASE_SERVICE_ROLE_KEY=
